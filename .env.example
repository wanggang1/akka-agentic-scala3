# Copy this file to .env and fill in your real values.
# .env is git-ignored; .env.example is the committed template.
#
# Load it into your shell before running the service, e.g.:
#   set -a && source .env && set +a && mvn compile exec:java

# Google AI Gemini API key (https://aistudio.google.com/app/apikey)
GOOGLE_AI_GEMINI_API_KEY=your-gemini-api-key
